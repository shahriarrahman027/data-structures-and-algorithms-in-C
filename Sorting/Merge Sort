#include <stdio.h>
#include <stdlib.h>

long long merge(int *a, int *temp, int left, int mid, int right) {
    int i, j, k;
    long long count = 0;

    i = left;
    j = mid + 1;
    k = left;

    while (i <= mid && j <= right) {
        if (a[i] <= a[j]) {
            temp[k++] = a[i++];
        } else {
            temp[k++] = a[j++];
            count += (mid - i + 1);
        }
    }

    while (i <= mid) {
        temp[k++] = a[i++];
    }

    while (j <= right) {
        temp[k++] = a[j++];
    }

    for (i = left; i <= right; i++) {
        a[i] = temp[i];
    }

    return count;
}

long long mergeSort(int *a, int *temp, int left, int right) {
    int mid;
    long long count = 0;

    if (left < right) {
        mid = (left + right) / 2;

        count += mergeSort(a, temp, left, mid);
        count += mergeSort(a, temp, mid + 1, right);
        count += merge(a, temp, left, mid, right);
    }

    return count;
}

int main() {
    int n, i;

    while (1) {
        scanf("%d", &n);

        if (n == 0) break;

        int *a = (int*)malloc(n * sizeof(int));
        int *temp = (int*)malloc(n * sizeof(int));

        for (i = 0; i < n; i++) {
            scanf("%d", &a[i]);
        }

        long long res = mergeSort(a, temp, 0, n - 1);

        printf("%lld\n", res);

        free(a);
        free(temp);
    }

    return 0;
}
