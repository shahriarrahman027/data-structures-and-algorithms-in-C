#include <stdio.h>

int main() {
    int n, i, j;
    int a[2000000];
    int count[100];
    while (1) {
        scanf("%d", &n);
        if (n == 0) break;
        for (i = 0; i < 100; i++)
            count[i] = 0;
        for (i = 0; i < n; i++) {
            scanf("%d", &a[i]);
            count[a[i]]++;
        }
        int first = 1;
        for (i = 1; i < 100; i++) {
            for (j = 0; j < count[i]; j++) {
                if (!first) printf(" ");
                printf("%d", i);
                first = 0;
            }
        }
        printf("\n");
    }
    return 0;
}
